# =============================================================================
# NEXUS-FORGE QaaS — Configuración de Entorno
# EPR-1 Universal Quantum Synchronization Protocol
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copia este archivo:  cp .env.example .env
#   2. Edita .env con tus valores
#   3. Lanza el sistema:    docker compose up --build -d
#
# Para instalación guiada:
#   chmod +x INSTALADOR/install.sh && bash INSTALADOR/install.sh
# =============================================================================

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Contraseña segura para el contenedor PostgreSQL.
# Mínimo 16 caracteres. Genera una con: openssl rand -hex 24
POSTGRES_PASSWORD=CAMBIA_ESTO_ANTES_DE_PRODUCCION

# ── Servidor API (Express 5) ──────────────────────────────────────────────────
# Entorno de ejecución — usar "production" en Docker.
NODE_ENV=production

# Puerto de escucha del servidor API (no cambiar sin actualizar docker-compose.yml).
PORT=8080

# Verbosidad de logs: trace | debug | info | warn | error
LOG_LEVEL=info

# URL pública del sistema. Usada en cabeceras CORS y en links del pitch.
# En local:      http://localhost:3000
# En producción: https://tu-dominio.com
PLATFORM_URL=http://localhost:3000

# ── Email — Resend (opcional) ─────────────────────────────────────────────────
# Necesario solo si usas el endpoint /api/pitch/send-email.
# Cuenta gratuita en https://resend.com (100 emails/día gratis).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Destinatario de los pitches (correo del comprador potencial).
PITCH_TO_EMAIL=comprador@ejemplo.com

# Remitente (debe pertenecer a tu dominio verificado en Resend).
# Deja en blanco para usar onboarding@resend.dev (solo plan gratuito).
PITCH_FROM_EMAIL=nexus@tudominio.com

# ── Constantes físicas (solo referencia — NO se modifican en runtime) ─────────
# Editar en:  artifacts/api-server/src/physics.config.ts
#
# T2_VACUUM_US=21.0            # μs — Place et al. 2021 (superconducting qubits)
# T1_RAD_ISS_US=100.0          # μs — Cardani et al. 2021 (LEO radiation)
# HOLEVO_CAPACITY_QUBITS=3.035 # qubits/uso — Holevo 1973 / HSW theorem
# LINK_FIDELITY_BASELINE=0.878 # 87.8% promedio DB real
# GATE_ERROR_RATE=0.00144      # 0.144% — surface code threshold
